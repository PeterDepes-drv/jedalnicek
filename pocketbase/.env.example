# Skopíruj tieto premenné do Coolify → Environment Variables pre službu PocketBase.
# Nikdy ich nedávaj do gitu ako .env súbor.

# Gemini API kľúč (zadarmo na https://aistudio.google.com/) — používa ho
# len server-side AI proxy (pb_hooks/ai_scan.pb.js), frontend ho nikdy nevidí.
GEMINI_API_KEY=

# Koľko AI skenov (recept + chladnička dokopy) smie jedna domácnosť spraviť za deň.
AI_SCAN_DAILY_LIMIT=5

# Celkový denný počet AI skenov naprieč VŠETKÝMI domácnosťami dokopy — poistka
# proti neplánovanému účtu pri raste počtu registrácií (verejný launch).
AI_SCAN_GLOBAL_DAILY_LIMIT=200
